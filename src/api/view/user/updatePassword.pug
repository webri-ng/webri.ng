extends ../layout.pug

block title
	| webri.ng | Update Password

block content
	h1 Update Password
	form(action='/user/update-password/form', method='post' onsubmit="return validateUpdatePasswordFormSubmission(event)")#update-password-form
		div.form-field
			label(for='currentPassword') Current Password: 
			input#password(type='password' name='currentPassword' minlength=2 maxlength=128 required='')
		div.form-field
		div.form-field
			label(for='newPassword') New Password: 
			input#password(type='password' name='newPassword' minlength=2 maxlength=128 required='')
		div.form-field
			label(for='confirmPassword') Confirm Password: 
			input#password(type='password' name='confirmPassword' minlength=2 maxlength=128 required='')
		div.form-buttons
			button(type='submit') Update Password
		div#error-message.error-message #{errorMessage}
